# PostgreSQL connection
POSTGRES_USER=stripes
POSTGRES_PASSWORD=stripes
POSTGRES_HOST=localhost
# POSTGRES_PORT is the host-published port (for CLI/scripts connecting from outside Docker).
# Inside Docker, the app always connects to the postgres service on port 5432.
POSTGRES_PORT=5432
POSTGRES_DB=stripes_rag

# --- Embedding ---
# Provider: "local" (sentence-transformers) or "litellm" (TEI, DeepInfra, OpenAI, Cohere, etc.)
# EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=64
# Override auto-detected embedding dimension (omit to probe the model at startup)
# EMBEDDING_DIM=1024

# LiteLLM: API base URL and key for OpenAI-compatible providers
# EMBEDDING_API_BASE=http://localhost:8080/v1
# EMBEDDING_API_KEY=

# --- Chunking ---
# HuggingFace tokenizer model for chunking (required when EMBEDDING_MODEL is not a HF repo id,
# e.g. when using Ollama). Defaults to EMBEDDING_MODEL.
# TOKENIZER_MODEL=BAAI/bge-m3
CHUNK_MAX_TOKENS=512

# --- Indexing ---
INDEX_BATCH_SIZE=128
MAX_FILE_SIZE_MB=50

# Vector index type: "hnsw" (high recall, default) or "ivfflat" (faster build)
VECTOR_INDEX_TYPE=hnsw

# --- Reranker (optional) ---
# Provider: "none" (disabled), "tei" (TEI /rerank endpoint), "litellm" (DeepInfra, Cohere, etc.), "llamacpp" (llama.cpp server)
# Auto-detected as "tei" when RERANKER_URL is set.
# RERANKER_PROVIDER=none
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# RERANKER_TOP_K_MULTIPLIER=3
# RERANKER_URL=http://localhost:8081

# --- Example: TEI server ---
# EMBEDDING_PROVIDER=litellm
# EMBEDDING_MODEL=openai/BAAI/bge-m3
# EMBEDDING_API_BASE=http://localhost:8080/v1
# RERANKER_URL=http://localhost:8081

# --- Example: DeepInfra ---
# EMBEDDING_PROVIDER=litellm
# EMBEDDING_MODEL=openai/BAAI/bge-m3
# EMBEDDING_API_BASE=https://api.deepinfra.com/v1/openai
# EMBEDDING_API_KEY=your-deepinfra-key
# RERANKER_PROVIDER=litellm
# RERANKER_MODEL=deepinfra/nvidia/llama-nemotron-rerank-vl-1b-v2
# DEEPINFRA_API_KEY=your-deepinfra-key

# --- Example: llama.cpp (embedding + reranking) ---
# llama-server --model bge-m3-Q8_0.gguf --port 8080 --embedding --pooling cls
# llama-server --model bge-reranker-v2-m3-Q8_0.gguf --port 8081 --reranking --pooling rank --embedding
# EMBEDDING_PROVIDER=litellm
# EMBEDDING_MODEL=openai/bge-m3-Q8_0
# EMBEDDING_API_BASE=http://localhost:8080/v1
# TOKENIZER_MODEL=BAAI/bge-m3
# RERANKER_PROVIDER=llamacpp
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# RERANKER_URL=http://localhost:8081
